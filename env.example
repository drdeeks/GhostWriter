# ================================
# GHOST WRITER - QUICK START
# 1. Copy this file to .env (`cp env.example .env`)
# 2. Fill in the required variables below.
# 3. For a full explanation of all variables, see docs/ENVIRONMENT.md
# ================================

# ================================
# DEPLOYMENT & BLOCKCHAIN
# ================================
NODE_ENV=development
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Required for contract deployment
PRIVATE_KEY=your_wallet_private_key

# Required for WalletConnect
NEXT_PUBLIC_ONCHAINKIT_PROJECT_ID=your_walletconnect_project_id

# RPC endpoints
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ================================
# SMART CONTRACT ADDRESSES
# These are updated automatically after deployment
# ================================
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_STORY_MANAGER_ADDRESS=0x...
NEXT_PUBLIC_LIQUIDITY_POOL_ADDRESS=0x...
NEXT_PUBLIC_PRICE_ORACLE_ADDRESS=0x...
NEXT_PUBLIC_TOKEN_ADDRESS=0x...

# ================================
# AI SERVICES (OPTIONAL)
# Enables AI story generation and moderation.
# ================================
OPENAI_API_KEY=sk-proj-your_openai_key_here

# AI Story Generation Tuning
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.9
OPENAI_MAX_TOKENS=700
OPENAI_TIMEOUT_MS=10000
AI_STORY_SYSTEM_PROMPT_APPEND=

# ================================
# NFT & FARCASTER (OPTIONAL)
# ================================
NFT_BACKGROUND_BASE_URL_LOCAL=/nft-backgrounds
NFT_BACKGROUND_BASE_URL_REMOTE=
NFT_BACKGROUND_CATEGORY_MAP='{}'
NEXT_PUBLIC_FARCASTER_MINIAPP_ID=ghost-writer

# ================================
# DEPLOYMENT & VERIFICATION (LOCAL ONLY)
# ================================
KEYSTORE_PATH=./keystores/warpcast.json
KEYSTORE_PASSWORD=
BASESCAN_API_KEY=your_basescan_api_key_here
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# ================================
# SERVER-SIDE SIGNER (REQUIRED)
# ================================
STORY_TEMPLATE_SIGNER_PRIVATE_KEY=0x...
STORY_TEMPLATE_SIGNER_ADDRESS=0x...

# ================================
# FEATURE FLAGS
# ================================
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_HAPTIC_FEEDBACK=true