# ============================================================================
# GHOST WRITER - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.
# ============================================================================

# ============================================================================
# BLOCKCHAIN NETWORK (Required)
# ============================================================================
# Which network to connect to:
#   8453  = Base Mainnet (production)
#   84532 = Base Sepolia (testnet)
NEXT_PUBLIC_CHAIN_ID=8453

# ============================================================================
# DEPLOYER WALLET (Required for contract deployment)
# ============================================================================
# Option 1: Direct private key (without 0x prefix is fine)
# Use for simple deployments or CI/CD
# PRIVATE_KEY=your_private_key_here

# Option 2: Encrypted keystore file (more secure for local dev)
# Create with: node create-keystore.js
# KEYSTORE_PATH=./keystores/deployer.json
# KEYSTORE_PASSWORD=your_keystore_password

# ============================================================================
# SMART CONTRACT ADDRESSES (Auto-populated after deployment)
# ============================================================================
# These are automatically set by the deploy script.
# Do not set manually unless migrating from another deployment.
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_STORY_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LIQUIDITY_POOL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PRICE_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: GHOST token address (deployed with --with-token flag)
# NEXT_PUBLIC_TOKEN_ADDRESS=0x...

# ============================================================================
# STORY TEMPLATE SIGNER (Required for user story creation)
# ============================================================================
# The private key used to sign EIP-712 approvals for story templates.
# This allows users to create stories with server-generated templates.
#
# SETUP:
# 1. Generate a new private key (do NOT use your deployer key)
# 2. Set STORY_TEMPLATE_SIGNER_PRIVATE_KEY below
# 3. Run: npx hardhat run scripts/set-signer.js --network base
#    (uses PRIVATE_KEY or KEYSTORE to call setStoryTemplateSigner as owner)
#
# The address derived from this key must match what's set on the contract.
# STORY_TEMPLATE_SIGNER_PRIVATE_KEY=0x...

# Optional: Set during deployment to auto-configure the signer address
# STORY_TEMPLATE_SIGNER_ADDRESS=0x...

# ============================================================================
# APPLICATION URL (Required for production)
# ============================================================================
# Base URL for the application. Used for NFT metadata URIs and Farcaster.
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ============================================================================
# RPC ENDPOINTS (Optional - uses public defaults)
# ============================================================================
# Custom RPC URLs for better reliability/performance.
# Recommended for production: Alchemy, Infura, or QuickNode.
# BASE_RPC_URL=https://mainnet.base.org
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ============================================================================
# ONCHAINKIT / WALLET CONNECT (Required for wallet UI)
# ============================================================================
# Get from: https://portal.cdp.coinbase.com/
# Free tier available for Base network.
NEXT_PUBLIC_ONCHAINKIT_PROJECT_ID=your_project_id
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_api_key

# ============================================================================
# AI STORY GENERATION (Optional - enables AI features)
# ============================================================================
# Get from: https://platform.openai.com/api-keys
# Without this, the app falls back to template-based story generation.
# OPENAI_API_KEY=sk-...

# AI Model Configuration (all optional, shown with defaults)
# OPENAI_MODEL=gpt-4o-mini          # Model to use for generation
# OPENAI_TEMPERATURE=0.9            # Creativity (0.0-2.0, higher = more creative)
# OPENAI_MAX_TOKENS=700             # Max tokens per response
# OPENAI_TIMEOUT_MS=10000           # API timeout in milliseconds

# Custom system prompt addition (appended to default prompt)
# AI_STORY_SYSTEM_PROMPT_APPEND=Make stories extra funny.

# ============================================================================
# FARCASTER INTEGRATION (Optional)
# ============================================================================
# For Farcaster Mini App / Frame integration.
NEXT_PUBLIC_FARCASTER_MINIAPP_ID=ghost-writer

# Optional: Farcaster API key for user lookups
# FARCASTER_API_KEY=your_api_key

# ============================================================================
# NFT IMAGE CUSTOMIZATION (Optional)
# ============================================================================
# Custom background images for NFTs by category.
# NFT_BACKGROUND_BASE_URL_LOCAL=/backgrounds/
# NFT_BACKGROUND_BASE_URL_REMOTE=https://your-cdn.com/backgrounds/
# NFT_BACKGROUND_CATEGORY_MAP={"adventure":"adventure.png","fantasy":"fantasy.png"}

# ============================================================================
# CONTRACT VERIFICATION (Optional)
# ============================================================================
# Required for verifying contracts on Basescan.
# Get from: https://basescan.org/myapikey
# BASESCAN_API_KEY=your_api_key

# ============================================================================
# GAS REPORTING (Optional - for development)
# ============================================================================
# Enable gas usage reports during contract tests.
# REPORT_GAS=true
# COINMARKETCAP_API_KEY=your_api_key  # For USD conversion

# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_HAPTIC_FEEDBACK=true

# ============================================================================
# VERCEL DEPLOYMENT CHECKLIST
# ============================================================================
# Copy these to Vercel Environment Variables:
#
# ✅ REQUIRED:
#   NEXT_PUBLIC_CHAIN_ID
#   NEXT_PUBLIC_BASE_URL
#   NEXT_PUBLIC_NFT_CONTRACT_ADDRESS
#   NEXT_PUBLIC_STORY_MANAGER_ADDRESS
#   NEXT_PUBLIC_LIQUIDITY_POOL_ADDRESS
#   NEXT_PUBLIC_PRICE_ORACLE_ADDRESS
#   NEXT_PUBLIC_ONCHAINKIT_PROJECT_ID
#   NEXT_PUBLIC_ONCHAINKIT_API_KEY
#   STORY_TEMPLATE_SIGNER_PRIVATE_KEY
#
# ✅ RECOMMENDED:
#   OPENAI_API_KEY
#   BASE_RPC_URL
#
# ✅ OPTIONAL:
#   NEXT_PUBLIC_TOKEN_ADDRESS
#   NEXT_PUBLIC_FARCASTER_MINIAPP_ID
#   ENABLE_PERFORMANCE_MONITORING
#   ENABLE_HAPTIC_FEEDBACK
#
# ❌ DO NOT ADD TO VERCEL (local only):
#   PRIVATE_KEY
#   KEYSTORE_PATH
#   KEYSTORE_PASSWORD
#   BASESCAN_API_KEY
#   REPORT_GAS
#   COINMARKETCAP_API_KEY
